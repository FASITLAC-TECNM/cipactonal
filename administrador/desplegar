#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Colors for pretty output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}=== Preparando despliegue para Railway ===${NC}\n"

# 1. Capture commit message
COMMIT_MSG="$1"

if [ -z "$COMMIT_MSG" ]; then
    echo -e "${RED}Error: Debes proporcionar un mensaje para el commit.${NC}"
    echo -e "Uso: ./desplegar \"mensaje del commit\""
    exit 1
fi

# 2. Check for git changes
if [ -z "$(git status --porcelain)" ]; then
    echo -e "${YELLOW}No hay cambios para confirmar en Git.${NC}"
    read -p "¿Deseas intentar hacer push de todos modos? (s/n): " PUSH_ANYWAY
    if [[ "$PUSH_ANYWAY" != "s" && "$PUSH_ANYWAY" != "S" ]]; then
        exit 0
    fi
else
    # 3. Synchronize lockfile (crucial for Railway to avoid lockfile out of date errors)
    echo -e "${BLUE}[1/3] Sincronizando pnpm-lock.yaml...${NC}"
    pnpm install --no-frozen-lockfile
fi

# 4. Verify build succeeds locally
echo -e "${BLUE}[2/3] Verificando compilación local (pnpm run build)...${NC}"
if pnpm run build; then
    echo -e "${GREEN}✓ La compilación se completó con éxito.${NC}"
else
    echo -e "${RED}✗ Error de compilación detectado. Abortando despliegue para evitar fallos en Railway.${NC}"
    exit 1
fi

# 5. Git Commit and Push
CURRENT_BRANCH=$(git branch --show-current)
echo -e "${BLUE}[3/3] Subiendo cambios a la rama '${CURRENT_BRANCH}'...${NC}"

if [ ! -z "$(git status --porcelain)" ]; then
    git add .
    git commit -m "$COMMIT_MSG"
fi

git push origin "$CURRENT_BRANCH"

echo -e "\n${GREEN}=== ¡Listo! Despliegue iniciado en Railway ===${NC}"
